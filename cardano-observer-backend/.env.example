# ── cardano-observer-backend configuration ──────────────────────────────────
# Copy this file to `.env` next to the binary (or export the variables) and
# point DBSYNC_URL at your cardano-db-sync PostgreSQL database.
# These names do not collide with cardano-observer's, so both processes can
# share a single .env file at the repository root if you prefer.

# PostgreSQL connection URL for cardano-db-sync (required).
# Run this backend on the same host as db-sync and local trust auth works
# without a password. Add :password after the user if your server requires one.
DBSYNC_URL=postgres://username@localhost:5432/cexplorer

# Maximum PostgreSQL connections in the pool.
DBSYNC_MAX_CONNECTIONS=8

# Server-side statement timeout in milliseconds (0 disables).
DBSYNC_STATEMENT_TIMEOUT_MS=60000

# Address & port the API listens on.
BACKEND_BIND=0.0.0.0:3300

# Network: mainnet | preprod | preview (stake address validation and identity).
NETWORK=mainnet

# Log level (error|warn|info|debug|trace)
RUST_LOG=info
