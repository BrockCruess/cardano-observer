# ── cardano-observer configuration ───────────────────────────────────────────
# Copy this file to `.env` and fill in the hosts/ports for your own services.

# Ogmios WebSocket endpoint (required for live mode - this is the event source).
# Not used when DEMO=true. cardano-observer follows the chain via Ogmios chain-sync.
OGMIOS_URL=ws://127.0.0.1:1337

# Use the bundled self-hosted API (cardano-observer-backend) instead of
# Blockfrost for all metadata / account / tx enrichment. It speaks the same
# HTTP API and queries your cardano-db-sync PostgreSQL directly - see
# cardano-observer-backend/README.md for setup. When true, BLOCKFROST_URL and
# BLOCKFROST_PROJECT_ID are ignored. (true/false)
USE_OBSERVER_BACKEND=false

# Base URL of cardano-observer-backend (used only when USE_OBSERVER_BACKEND=true).
OBSERVER_BACKEND_URL=http://127.0.0.1:3300

# cardano-observer-backend settings (only when USE_OBSERVER_BACKEND=true).
# start.sh / start-dev.sh read these from THIS root .env: when DBSYNC_URL is set
# they build and launch the backend locally alongside the observer; when it is
# empty they assume the backend runs elsewhere and only OBSERVER_BACKEND_URL is
# used. Point DBSYNC_URL at your cardano-db-sync PostgreSQL (same host + local
# trust auth needs no password; add :password after the user otherwise).
# Leave DBSYNC_URL empty if the backend runs on a different machine.
DBSYNC_URL=postgres://dbsync@localhost:5432/cexplorer
# Address & port the backend listens on (its OBSERVER_BACKEND_URL should match).
BACKEND_BIND=0.0.0.0:3300
# Backend PostgreSQL pool size and per-statement timeout in ms (0 disables).
DBSYNC_MAX_CONNECTIONS=8
DBSYNC_STATEMENT_TIMEOUT_MS=60000

# Blockfrost RYO (run-your-own) base URL (optional but recommended).
# Used for pool/drep/gov-action metadata, stake-account lookups (delegation from→to),
# historical tx detail when a tx has left the in-memory cache, the recurring
# pool-ticker / DRep scrapes into DATA_DIR/pools.json and DATA_DIR/dreps.json
# (also refreshed daily at 00:00 UTC), and first-sight CIP-108 gov-action titles
# into DATA_DIR/gov-actions.json. Asset decimals/tickers come from the local
# CIP-26 cache, not Blockfrost. Needs cardano-db-sync behind it.
# Leave empty to disable. Example self-hosted: http://127.0.0.1:3000
BLOCKFROST_URL=http://127.0.0.1:3000

# project_id header for Blockfrost. RYO instances usually don't need one -
# leave empty unless yours does (or you point BLOCKFROST_URL at the public API).
BLOCKFROST_PROJECT_ID=

# ADA Handle resolver base URL. Used to replace truncated stake addresses on
# event cards with the account's preferred $handle (when they have one).
# Defaults to the free public API for NETWORK (https://api.handle.me on mainnet,
# https://preprod.api.handle.me / https://preview.api.handle.me on testnets).
# Point at a self-hosted instance if you run one locally, e.g.:
#   http://127.0.0.1:3141   (KoraLabs handles-public-api)
#   http://127.0.0.1:9095   (Cardano Foundation cf-adahandle-resolver)
# Set to none / off / false to disable Handle enrichment.
ADA_HANDLE_URL=

# Which Handle HTTP API shape to speak: auto | kora | cf
# auto (default) picks CF when the URL looks like the CF resolver (port 9095 /
# "adahandle"), otherwise KoraLabs (/holders/{address} → default_handle).
ADA_HANDLE_API=auto

# CIP-26 mappings zip used on first boot (or when TOKEN_REGISTRY_REFRESH is set)
# to build DATA_DIR/token-registry.json. Later boots load that cache file.
TOKEN_REGISTRY_ZIP=https://github.com/cardano-foundation/cardano-token-registry/archive/refs/heads/master.zip

# Set to true/1/yes to re-download TOKEN_REGISTRY_ZIP even if the cache exists.
TOKEN_REGISTRY_REFRESH=false

# Set to true/1/yes to re-scrape Blockfrost /pools into DATA_DIR/pools.json on boot.
# While running, pools.json is also overwritten daily at 00:00 UTC.
POOL_CACHE_REFRESH=false

# Set to true/1/yes to re-scrape Blockfrost /governance/dreps into DATA_DIR/dreps.json on boot.
# While running, dreps.json is also overwritten daily at 00:00 UTC.
DREP_CACHE_REFRESH=false

# Known scam-token CIP-14 fingerprints (asset1…). Upstream text list is parsed into
# DATA_DIR/scam-tokens.json on first boot; refreshed daily at 00:00 UTC. Token-transfer
# cards that move a listed asset show a scam warning in the UI.
SCAM_TOKEN_LIST_URL=https://raw.githubusercontent.com/BrockCruess/Cardano-Scam-Token-Registry/refs/heads/main/scam-token-list
SCAM_TOKEN_LIST_REFRESH=false

# Network: mainnet | preprod | preview  (address encoding and explorer links;
# slot→time conversion is discovered from Ogmios itself)
NETWORK=mainnet

# Address & port the web UI listens on
BIND=0.0.0.0:9070

# Directory for persisted events/txs (JSONL) plus registry/pool/drep caches.
# Default ./data. Set to none/off/false to disable persistence.
DATA_DIR=./data

# On restart, resume chain-sync from the last persisted block if it is at most
# this many hours old. 0 = always start at the tip (no backfill).
BACKFILL_HOURS=24

# How many hours of events to keep in memory for trending + fast search.
# Disk under DATA_DIR still retains full history for deeper scrollback.
EVENT_RETENTION_HOURS=24

# Soft max for in-memory transaction bodies (0 = keep all txs in the
# EVENT_RETENTION_HOURS window). Full tx history stays on disk forever
# (hash-indexed) so deep scrollback can still open transaction details.
# A positive value can drop recent in-memory txs under load — leave at 0
# unless memory is constrained.
TX_CACHE=0

# Demo mode: generate synthetic chain events instead of connecting to Ogmios.
# Handy for trying the UI without a node. Persistence is forced off so synthetic
# events never pollute DATA_DIR. (true/false)
DEMO=false

# Log level (error|warn|info|debug|trace)
RUST_LOG=info
